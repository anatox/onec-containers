ARG BASE_IMAGE=ubuntu:26.04
ARG INSTALLER_IMAGE=installer:onec-installer
ARG EDT_VERSION
ARG CLIENT_IMAGE=scratch

FROM ${INSTALLER_IMAGE} AS installer

LABEL org.opencontainers.image.authors="Anatolii Sereda <3011745+anatox@users.noreply.github.com>"

ARG EDT_VERSION

COPY distr /distr
COPY --chmod=755 edt/install-edt-jdk.sh /install-edt-jdk.sh

# Установка JDK и библиотек для EDT
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked <<'EOF'
  set -euxo pipefail
  apt-get update -qq
  /install-edt-jdk.sh "$EDT_VERSION"

  DEBIAN_FRONTEND=noninteractive apt-get install -y -o=Dpkg::Use-Pty=0 --no-install-recommends \
    libc-bin \
    coreutils
  DEBIAN_FRONTEND=noninteractive xargs apt-get install -y -o=Dpkg::Use-Pty=0 --no-install-recommends < edt/packages.txt
  locale-gen ru_RU.UTF-8
  if [ -d /usr/share/applications ]; then find /usr/share/applications -maxdepth 1 -name '*.desktop' -delete; fi
EOF

# Скачивание и установка EDT
RUN --mount=type=cache,id=distr-cache,target=/var/cache/yard,sharing=locked \
    --mount=type=secret,id=secrets_env <<'EOF'
  set -euxo pipefail
  set -a; . /run/secrets/secrets_env >/dev/null 2>&1; set +a
  onec-install edt "$EDT_VERSION"
EOF

FROM ${CLIENT_IMAGE} AS client-src

FROM ${BASE_IMAGE} AS base

LABEL org.opencontainers.image.authors="Anatolii Sereda <3011745+anatox@users.noreply.github.com>"

ARG EDT_VERSION

WORKDIR /tmp

COPY --chmod=755 edt/install-edt-jdk.sh /install-edt-jdk.sh
COPY --chmod=755 edt/install-edt-nginx.sh /install-edt-nginx.sh

# Установка JDK и библиотек для финального образа
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked <<'EOF'
  set -euxo pipefail
  apt-get update -qq
  /install-edt-jdk.sh "$EDT_VERSION"

  DEBIAN_FRONTEND=noninteractive xargs apt-get install -y -o=Dpkg::Use-Pty=0 --no-install-recommends < edt/packages.txt
  locale-gen ru_RU.UTF-8
  if [ -d /usr/share/applications ]; then find /usr/share/applications -maxdepth 1 -name '*.desktop' -delete; fi
  /install-edt-nginx.sh
EOF

# Установка переменных окружения для корректной работы локали
ENV LANG=ru_RU.UTF-8
ENV LANGUAGE=ru_RU:ru
ENV LC_ALL=ru_RU.UTF-8

# Copy EDT
COPY --from=installer /opt/1C/1CE /opt/1C/1CE
COPY --from=installer /etc/1C/1CE /etc/1C/1CE
COPY --from=installer /usr/share/applications /usr/share/applications

ENV JAVA_HOME=/opt/1C/1CE/components/jdk-current
ENV PATH="$JAVA_HOME/bin:/opt/1C/1CE/components/1c-edt-current:/opt/1C/1CE/components/1c-edt-start-current:$PATH"

FROM base AS toolbox
COPY scripts/distrobox-shims.sh /distrobox-shims.sh

RUN <<'EOF'
  set -euxo pipefail
  chmod +x /distrobox-shims.sh
  /distrobox-shims.sh
  rm /distrobox-shims.sh
EOF

FROM toolbox AS toolbox-client

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked <<'EOF'
  set -euxo pipefail
  apt-get update -qq
  echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections
  DEBIAN_FRONTEND=noninteractive xargs apt-get install -y -o=Dpkg::Use-Pty=0 --no-install-recommends < client/packages.txt
  if [ -d /usr/share/applications ]; then find /usr/share/applications -maxdepth 1 -name '*.desktop' -delete; fi
EOF

COPY --from=client-src /opt /opt
COPY --from=client-src /usr/share/icons /usr/share/icons
COPY --from=client-src /usr/share/applications /usr/share/applications

COPY scripts/distrobox-shims.sh /distrobox-shims.sh

RUN <<'EOF'
  set -euxo pipefail
  chmod +x /distrobox-shims.sh
  /distrobox-shims.sh
  rm /distrobox-shims.sh
EOF

FROM base AS edt
